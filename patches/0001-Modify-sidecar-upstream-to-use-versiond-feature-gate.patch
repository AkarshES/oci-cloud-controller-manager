From a2f316cb5721197f37d5840094464a8a94b439c1 Mon Sep 17 00:00:00 2001
From: unepatel <uneet.patel@oracle.com>
Date: Tue, 13 May 2025 16:51:21 +0530
Subject: [PATCH] [Patch] Remove HonorPVReclaimPolicy flag from
 external-provisioner for 1.33

---
 .../external-resizer/pkg/features/features.go      | 14 ++++++++++++--
 1 file changed, 12 insertions(+), 2 deletions(-)

diff --git a/vendor/github.com/kubernetes-csi/external-resizer/pkg/features/features.go b/vendor/github.com/kubernetes-csi/external-resizer/pkg/features/features.go
index ba5f7e4bd..98e9f1a9c 100644
--- a/vendor/github.com/kubernetes-csi/external-resizer/pkg/features/features.go
+++ b/vendor/github.com/kubernetes-csi/external-resizer/pkg/features/features.go
@@ -19,6 +19,7 @@ package features
 import (
 	utilfeature "k8s.io/apiserver/pkg/util/feature"
 	"k8s.io/component-base/featuregate"
+	"k8s.io/apimachinery/pkg/util/version"
 )
 
 const (
@@ -44,10 +45,19 @@ const (
 
 func init() {
 	utilfeature.DefaultMutableFeatureGate.Add(defaultResizerFeatureGates)
+	utilfeature.DefaultMutableFeatureGate.AddVersioned(defaultResizerVersionedFeatureGates)
 }
 
 var defaultResizerFeatureGates = map[featuregate.Feature]featuregate.FeatureSpec{
 	AnnotateFsResize:              {Default: false, PreRelease: featuregate.Alpha},
-	RecoverVolumeExpansionFailure: {Default: true, PreRelease: featuregate.Beta},
-	VolumeAttributesClass:         {Default: false, PreRelease: featuregate.Beta},
+}
+var defaultResizerVersionedFeatureGates = map[featuregate.Feature]featuregate.VersionedSpecs{
+	RecoverVolumeExpansionFailure: {
+		{Version: version.MustParse("1.23"), Default: false, PreRelease: featuregate.Alpha},
+		{Version: version.MustParse("1.32"), Default: true, PreRelease: featuregate.Beta},
+	},
+	VolumeAttributesClass :{
+		{Version: version.MustParse("1.29"), Default: false, PreRelease: featuregate.Alpha},
+		{Version: version.MustParse("1.31"), Default: false, PreRelease: featuregate.Beta},
+	},
 }
-- 
